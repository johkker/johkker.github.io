---
import Layout from '../layouts/Layout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

const features = [
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M15 10.5a3 3 0 11-6 0 3 3 0 016 0z" /><path stroke-linecap="round" stroke-linejoin="round" d="M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1115 0z" /></svg>`,
    title: 'Descubra Batalhas',
    description: 'Encontre batalhas de rap perto de voce com mapa interativo e filtros por cidade.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M16.5 18.75h-9m9 0a3 3 0 013 3h-15a3 3 0 013-3m9 0v-3.375c0-.621-.503-1.125-1.125-1.125h-.871M7.5 18.75v-3.375c0-.621.504-1.125 1.125-1.125h.872m5.007 0H9.497m5.007 0a7.454 7.454 0 01-.982-3.172M9.497 14.25a7.454 7.454 0 00.981-3.172M5.25 4.236c-.982.143-1.954.317-2.916.52A6.003 6.003 0 007.73 9.728M5.25 4.236V4.5c0 2.108.966 3.99 2.48 5.228M5.25 4.236V2.721C7.456 2.41 9.71 2.25 12 2.25c2.291 0 4.545.16 6.75.47v1.516M18.75 4.236c.982.143 1.954.317 2.916.52A6.003 6.003 0 0016.27 9.728M18.75 4.236V4.5c0 2.108-.966 3.99-2.48 5.228m0 0a6.003 6.003 0 01-2.48-5.228V2.72a49.944 49.944 0 00-6.54 0v1.507a6.003 6.003 0 01-2.48 5.228" /></svg>`,
    title: 'Rankings e Trofeus',
    description: 'Acompanhe o desempenho dos MCs, conquiste trofeus e suba no ranking.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M18 18.72a9.094 9.094 0 003.741-.479 3 3 0 00-4.682-2.72m.94 3.198l.001.031c0 .225-.012.447-.037.666A11.944 11.944 0 0112 21c-2.17 0-4.207-.576-5.963-1.584A6.062 6.062 0 016 18.719m12 0a5.971 5.971 0 00-.941-3.197m0 0A5.995 5.995 0 0012 12.75a5.995 5.995 0 00-5.058 2.772m0 0a3 3 0 00-4.681 2.72 8.986 8.986 0 003.74.477m.94-3.197a5.971 5.971 0 00-.94 3.197M15 6.75a3 3 0 11-6 0 3 3 0 016 0zm6 3a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0zm-13.5 0a2.25 2.25 0 11-4.5 0 2.25 2.25 0 014.5 0z" /></svg>`,
    title: 'Conecte-se com a Cena',
    description: 'Siga MCs, curta batalhas e fique por dentro de tudo que rola na cena.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6.75 3v2.25M17.25 3v2.25M3 18.75V7.5a2.25 2.25 0 012.25-2.25h13.5A2.25 2.25 0 0121 7.5v11.25m-18 0A2.25 2.25 0 005.25 21h13.5A2.25 2.25 0 0021 18.75m-18 0v-7.5A2.25 2.25 0 015.25 9h13.5A2.25 2.25 0 0121 11.25v7.5" /></svg>`,
    title: 'Calendario de Eventos',
    description: 'Nunca perca uma batalha. Veja datas, horarios e locais de todos os eventos.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M9.568 3H5.25A2.25 2.25 0 003 5.25v4.318c0 .597.237 1.17.659 1.591l9.581 9.581c.699.699 1.78.872 2.607.33a18.095 18.095 0 005.223-5.223c.542-.827.369-1.908-.33-2.607L11.16 3.66A2.25 2.25 0 009.568 3z" /><path stroke-linecap="round" stroke-linejoin="round" d="M6 6h.008v.008H6V6z" /></svg>`,
    title: 'Campeonatos',
    description: 'Organize e participe de campeonatos com chaveamento e resultados em tempo real.',
  },
  {
    icon: `<svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5"><path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5m.75-9l3-3 2.148 2.148A12.061 12.061 0 0116.5 7.605" /></svg>`,
    title: 'Painel Admin',
    description: 'Gerencie suas batalhas com ferramentas de admin: edicoes, resultados e estatisticas.',
  },
];

const faqs = [
  {
    q: 'O que e o RapTrak?',
    a: 'O RapTrak e uma plataforma para descobrir, acompanhar e gerenciar batalhas de rap no Brasil. Pense em uma rede social feita pela e para a cena do rap.',
  },
  {
    q: 'Como acesso a versao web?',
    a: 'A versao web esta disponivel em app.raptrak.me. Basta criar uma conta com email ou entrar com sua conta Google.',
  },
  {
    q: 'Quando o app Android estara disponivel?',
    a: 'Estamos em fase de beta fechado no Android. Voce pode solicitar acesso preenchendo o formulario nesta pagina. Enviaremos um convite assim que novas vagas abrirem.',
  },
  {
    q: 'E o iOS?',
    a: 'O app iOS esta nos planos! Por enquanto, voce pode acessar todas as funcionalidades pela versao web no seu iPhone.',
  },
  {
    q: 'Preciso pagar algo?',
    a: 'Nao! O RapTrak e gratuito para todos os usuarios. Organizadores de batalha tem acesso a todas as ferramentas de gestao sem custo.',
  },
  {
    q: 'Como faco para cadastrar minha batalha?',
    a: 'Apos criar sua conta, voce pode cadastrar uma batalha pela plataforma. O cadastro passa por uma aprovacao rapida para garantir a qualidade do conteudo.',
  },
  {
    q: 'Meus dados estao seguros?',
    a: 'Sim. Seguimos a LGPD e voce pode solicitar a exclusao dos seus dados a qualquer momento. Veja nossa politica de privacidade para mais detalhes.',
  },
  {
    q: 'Como excluo minha conta?',
    a: 'Voce pode solicitar a exclusao diretamente no app (Configuracoes > Excluir Conta) ou pela nossa pagina de exclusao de dados. Sua conta sera removida permanentemente apos 30 dias.',
  },
];
---

<Layout title="RapTrak — A plataforma da cena do rap brasileiro">
  <Header />

  <!-- Hero -->
  <section class="relative min-h-screen flex items-center justify-center pt-16 overflow-hidden">
    <!-- Background effects -->
    <div class="absolute inset-0">
      <div class="absolute top-1/4 left-1/4 w-96 h-96 bg-accent/10 rounded-full blur-[128px] animate-float"></div>
      <div class="absolute bottom-1/4 right-1/4 w-80 h-80 bg-accent-secondary/10 rounded-full blur-[128px] animate-float-delayed"></div>
    </div>

    <!-- Grid pattern -->
    <div class="absolute inset-0 opacity-[0.03]" style="background-image: linear-gradient(rgba(139,92,246,0.3) 1px, transparent 1px), linear-gradient(90deg, rgba(139,92,246,0.3) 1px, transparent 1px); background-size: 60px 60px;"></div>

    <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <!-- Badge -->
      <div class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full glass text-xs font-medium text-accent-light mb-8 animate-fade-in">
        <span class="w-2 h-2 rounded-full bg-green-400 animate-pulse"></span>
        Beta aberto na web &middot; Android em breve
      </div>

      <!-- Headline -->
      <h1 class="font-display text-5xl sm:text-6xl lg:text-7xl font-bold leading-tight mb-6 animate-slide-up">
        A plataforma da<br />
        <span class="gradient-text">cena do rap</span> brasileiro
      </h1>

      <p class="text-lg sm:text-xl text-text-secondary max-w-2xl mx-auto mb-10 animate-slide-up" style="animation-delay: 0.15s">
        Descubra batalhas perto de voce, acompanhe rankings, conquiste trofeus e conecte-se com MCs de todo o Brasil.
      </p>

      <!-- CTAs -->
      <div class="flex flex-col sm:flex-row items-center justify-center gap-4 animate-slide-up" style="animation-delay: 0.3s">
        <a
          href="https://app.raptrak.me"
          class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-xl bg-gradient-to-r from-accent to-accent-secondary text-white font-semibold text-base hover:shadow-xl hover:shadow-accent-glow transition-all duration-300 hover:-translate-y-1"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3.75 3v11.25A2.25 2.25 0 006 16.5h2.25M3.75 3h-1.5m1.5 0h16.5m0 0h1.5m-1.5 0v11.25A2.25 2.25 0 0118 16.5h-2.25m-7.5 0h7.5m-7.5 0l-1 3m8.5-3l1 3m0 0l.5 1.5m-.5-1.5h-9.5m0 0l-.5 1.5" />
          </svg>
          Acessar Web App
        </a>
        <a
          href="#beta"
          class="w-full sm:w-auto inline-flex items-center justify-center gap-2 px-8 py-3.5 rounded-xl glass glass-hover text-text-primary font-semibold text-base transition-all duration-300 hover:-translate-y-1"
        >
          <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M10.5 1.5H8.25A2.25 2.25 0 006 3.75v16.5a2.25 2.25 0 002.25 2.25h7.5A2.25 2.25 0 0018 20.25V3.75a2.25 2.25 0 00-2.25-2.25H13.5m-3 0V3h3V1.5m-3 0h3m-3 18.75h3" />
          </svg>
          Testar no Android
        </a>
      </div>

      <!-- Scroll indicator -->
      <div class="mt-16 lg:mt-24 animate-bounce">
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 mx-auto text-text-muted" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
        </svg>
      </div>
    </div>
  </section>

  <!-- Features -->
  <section id="features" class="py-24 lg:py-32">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-16" data-animate>
        <p class="text-accent font-mono text-sm font-medium uppercase tracking-widest mb-3">Features</p>
        <h2 class="font-display text-3xl sm:text-4xl font-bold mb-4">
          Tudo que a cena precisa,<br class="hidden sm:block" /> em um so lugar
        </h2>
        <p class="text-text-secondary max-w-xl mx-auto">
          Ferramentas feitas por quem vive a cena, para quem vive a cena.
        </p>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {features.map((feature, i) => (
          <div
            class="group p-6 rounded-2xl glass glass-hover transition-all duration-300 hover:-translate-y-1"
            data-animate
            style={`transition-delay: ${i * 0.08}s`}
          >
            <div class="w-12 h-12 rounded-xl bg-accent/10 text-accent flex items-center justify-center mb-4 group-hover:bg-accent/20 transition-colors">
              <Fragment set:html={feature.icon} />
            </div>
            <h3 class="font-display font-semibold text-lg mb-2">{feature.title}</h3>
            <p class="text-text-secondary text-sm leading-relaxed">{feature.description}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Beta Request -->
  <section id="beta" class="py-24 lg:py-32 relative">
    <div class="absolute inset-0">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[600px] h-[600px] bg-accent/5 rounded-full blur-[128px]"></div>
    </div>

    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12" data-animate>
        <p class="text-accent font-mono text-sm font-medium uppercase tracking-widest mb-3">Beta Android</p>
        <h2 class="font-display text-3xl sm:text-4xl font-bold mb-4">
          Quer testar no Android?
        </h2>
        <p class="text-text-secondary max-w-lg mx-auto">
          Estamos em beta fechado. Deixe seu email e voce sera um dos primeiros a ter acesso ao app nativo.
        </p>
      </div>

      <div class="glass rounded-2xl p-8 sm:p-10" data-animate>
        <form id="beta-form" class="space-y-5">
          <div class="grid grid-cols-1 sm:grid-cols-2 gap-5">
            <div>
              <label for="beta-name" class="block text-sm font-medium text-text-secondary mb-1.5">Nome</label>
              <input
                type="text"
                id="beta-name"
                name="name"
                required
                placeholder="Seu nome"
                class="w-full px-4 py-3 rounded-xl bg-bg-primary border border-border text-text-primary placeholder-text-muted text-sm focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-colors"
              />
            </div>
            <div>
              <label for="beta-email" class="block text-sm font-medium text-text-secondary mb-1.5">Email</label>
              <input
                type="email"
                id="beta-email"
                name="email"
                required
                placeholder="seu@email.com"
                class="w-full px-4 py-3 rounded-xl bg-bg-primary border border-border text-text-primary placeholder-text-muted text-sm focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-colors"
              />
            </div>
          </div>

          <div>
            <label for="beta-message" class="block text-sm font-medium text-text-secondary mb-1.5">
              Como voce conheceu o RapTrak? <span class="text-text-muted">(opcional)</span>
            </label>
            <textarea
              id="beta-message"
              name="message"
              rows="3"
              placeholder="Conta pra gente..."
              class="w-full px-4 py-3 rounded-xl bg-bg-primary border border-border text-text-primary placeholder-text-muted text-sm focus:outline-none focus:border-accent focus:ring-1 focus:ring-accent transition-colors resize-none"
            ></textarea>
          </div>

          <button
            type="submit"
            id="beta-submit"
            class="w-full py-3.5 rounded-xl bg-gradient-to-r from-accent to-accent-secondary text-white font-semibold text-sm hover:shadow-lg hover:shadow-accent-glow transition-all duration-300 hover:-translate-y-0.5 disabled:opacity-50 disabled:cursor-not-allowed disabled:hover:translate-y-0"
          >
            Quero participar do beta
          </button>
        </form>

        <!-- Success message -->
        <div id="beta-success" class="hidden text-center py-8">
          <div class="w-16 h-16 rounded-full bg-green-500/10 text-green-400 flex items-center justify-center mx-auto mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
              <path stroke-linecap="round" stroke-linejoin="round" d="M4.5 12.75l6 6 9-13.5" />
            </svg>
          </div>
          <h3 class="font-display text-xl font-bold mb-2">Voce esta na lista!</h3>
          <p class="text-text-secondary text-sm">
            Fique de olho no seu email. Enviaremos o convite assim que sua vaga abrir.
          </p>
        </div>

        <!-- Error message -->
        <div id="beta-error" class="hidden mt-4 p-4 rounded-xl bg-red-500/10 border border-red-500/20 text-red-400 text-sm text-center">
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section id="faq" class="py-24 lg:py-32">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-12" data-animate>
        <p class="text-accent font-mono text-sm font-medium uppercase tracking-widest mb-3">FAQ</p>
        <h2 class="font-display text-3xl sm:text-4xl font-bold mb-4">
          Perguntas frequentes
        </h2>
      </div>

      <div class="space-y-3" data-animate>
        {faqs.map((faq, i) => (
          <details class="group glass rounded-xl overflow-hidden">
            <summary class="flex items-center justify-between gap-4 px-6 py-4 cursor-pointer list-none text-text-primary font-medium text-sm hover:bg-bg-card-hover/30 transition-colors">
              <span>{faq.q}</span>
              <svg xmlns="http://www.w3.org/2000/svg" class="w-4 h-4 text-text-muted shrink-0 transition-transform duration-200 group-open:rotate-180" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                <path stroke-linecap="round" stroke-linejoin="round" d="M19.5 8.25l-7.5 7.5-7.5-7.5" />
              </svg>
            </summary>
            <div class="px-6 pb-4 text-text-secondary text-sm leading-relaxed">
              {faq.a}
            </div>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- Final CTA -->
  <section class="py-24 lg:py-32 relative">
    <div class="absolute inset-0">
      <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-accent/30 to-transparent"></div>
    </div>

    <div class="relative max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center" data-animate>
      <h2 class="font-display text-3xl sm:text-4xl font-bold mb-4">
        Pronto pra entrar na cena?
      </h2>
      <p class="text-text-secondary mb-8 max-w-lg mx-auto">
        Junte-se a comunidade que esta conectando as batalhas de rap de todo o Brasil.
      </p>
      <a
        href="https://app.raptrak.me"
        class="inline-flex items-center gap-2 px-8 py-3.5 rounded-xl bg-gradient-to-r from-accent to-accent-secondary text-white font-semibold text-base hover:shadow-xl hover:shadow-accent-glow transition-all duration-300 hover:-translate-y-1"
      >
        Comecar agora
        <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path stroke-linecap="round" stroke-linejoin="round" d="M13 7l5 5m0 0l-5 5m5-5H6" />
        </svg>
      </a>
    </div>
  </section>

  <Footer />
</Layout>

<script>
  const API_URL = 'https://raptrak-production.up.railway.app';
  const form = document.getElementById('beta-form') as HTMLFormElement;
  const submitBtn = document.getElementById('beta-submit') as HTMLButtonElement;
  const successDiv = document.getElementById('beta-success')!;
  const errorDiv = document.getElementById('beta-error')!;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    submitBtn.disabled = true;
    submitBtn.textContent = 'Enviando...';
    errorDiv.classList.add('hidden');

    const name = (document.getElementById('beta-name') as HTMLInputElement).value;
    const email = (document.getElementById('beta-email') as HTMLInputElement).value;
    const message = (document.getElementById('beta-message') as HTMLTextAreaElement).value;

    try {
      const res = await fetch(`${API_URL}/beta-request`, {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({ name, email, message: message || undefined, platform: 'android' }),
      });

      if (res.ok) {
        form.classList.add('hidden');
        successDiv.classList.remove('hidden');
      } else {
        const data = await res.json();
        errorDiv.textContent = data.message || 'Erro ao enviar. Tente novamente.';
        errorDiv.classList.remove('hidden');
        submitBtn.disabled = false;
        submitBtn.textContent = 'Quero participar do beta';
      }
    } catch {
      errorDiv.textContent = 'Erro de conexao. Verifique sua internet e tente novamente.';
      errorDiv.classList.remove('hidden');
      submitBtn.disabled = false;
      submitBtn.textContent = 'Quero participar do beta';
    }
  });
</script>
